// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`YearSelector > should render years sorted from newest to oldest 1`] = `
<div>
  <select
    aria-label="Year"
    data-testid="year-selector"
  >
    <option
      value=""
    >
      None
    </option>
    <option
      value="2024"
    >
      2024
    </option>
    <option
      value="2023"
    >
      2023
    </option>
    <option
      value="2022"
    >
      2022
    </option>
  </select>
</div>
`;
